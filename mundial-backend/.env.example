POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mundial
POSTGRES_PASSWORD=mundial
POSTGRES_DB=mundial

JWT_SECRET=zmien-na-losowy-string-minimum-32-znaki
JWT_EXPIRE_DAYS=7

# wymagaj potwierdzenia emaila przed logowaniem. zostaw false na dev (sandbox
# resend wysyla maile tylko na wlasny adres), ustaw true na produkcji
# ustaw TRUE na produkcji — weryfikacja emaila przed pierwszym logowaniem
REQUIRE_VERIFIED_EMAIL=false

# emaile użytkowników którzy mogą wpisywać wyniki meczów (POST /matches/{id}/result)
# lista oddzielona przecinkami, bez spacji. zobacz docs/decisions.md #005
ADMIN_EMAILS=

FOOTBALL_API_KEY=twoj-klucz-z-football-data.org
RESEND_API_KEY=twoj-klucz-z-resend.com
# adres nadawcy maili. domyslnie sandbox resend.dev (wysyla tylko na twoj email).
# po weryfikacji wlasnej domeny zmien na np. "Mundial Typer <noreply@twojadomena.pl>"
EMAIL_FROM=Mundial Typer <onboarding@resend.dev>

# na produkcji: https://twojadomena.vercel.app
# wiele originu (dev + prod): http://localhost:5173,https://mundialtyper.vercel.app
FRONTEND_URL=http://localhost:5173

# wstaw testowe dane (48 drużyn, 104 mecze, 5 kont) przy starcie serwera
# ustaw na false na produkcji!
DEV_SEED=false
